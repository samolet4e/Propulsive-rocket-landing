<?xml version="1.0"?>

<PropertyList>
  <generic>
    <input>

      <line_separator>newline</line_separator>
      <var_separator> </var_separator>

	  <chunk>
        <name>time</name>
        <type>double</type>
        <format>%f</format>
        <node>/sim/time/elapsed-sec</node>
      </chunk>

      <!-- POSITION -->
      <chunk>
        <name>latitude</name>
        <type>double</type>
        <format>%lf</format>
        <node>/position/latitude-deg</node>
      </chunk>

      <chunk>
        <name>longitude</name>
        <type>double</type>
        <format>%lf</format>
        <node>/position/longitude-deg</node>
      </chunk>

      <chunk>
        <name>altitude</name>
        <type>double</type>
        <format>%lf</format>
        <node>/position/altitude-ft</node>
      </chunk>

      <!-- ATTITUDE -->

      <chunk>
        <name>roll</name>
        <type>double</type>
        <format>%lf</format>
        <node>/orientation/roll-deg</node>
      </chunk>

      <chunk>
        <name>pitch</name>
        <type>double</type>
        <format>%lf</format>
        <node>/orientation/pitch-deg</node>
      </chunk>

      <chunk>
        <name>heading</name>
        <type>double</type>
        <format>%lf</format>
        <node>/orientation/heading-deg</node>
      </chunk>

    </input>
  </generic>
</PropertyList>